generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ─── AUTH.JS MODELS ──────────────────────────────────────────────────────────

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?
  accounts      Account[]
  sessions      Session[]

  // App relations
  memberships        OrganizationMember[]
  teamMemberships    TeamMember[]
  createdProjects    Project[]       @relation("ProjectCreator")
  assignedActivities Activity[]      @relation("ActivityAssignee")
  submittedPow       PowSubmission[] @relation("PowSubmitter")
  reviewedPow        PowSubmission[] @relation("PowReviewer")
  uploadedDocuments  VaultDocument[] @relation("VaultUploader")
  notifications      Notification[]
  activeOrgId        String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ─── ENUMS ────────────────────────────────────────────────────────────────────

enum MemberRole {
  OWNER
  ADMIN
  MEMBER
  VIEWER
}

enum ActivityStatus {
  TODO
  IN_PROGRESS
  PENDING_VERIFICATION
  VERIFIED
}

enum Priority {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum PowStatus {
  NOT_SUBMITTED
  AWAITING_REVIEW
  APPROVED
  REJECTED
}

enum MilestoneStatus {
  NOT_STARTED
  IN_PROGRESS
  AT_RISK
  COMPLETED
  DELAYED
}

enum VelocityRisk {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum NotificationType {
  VERIFICATION
  DEADLINE
  COMMENT
  ASSIGNMENT
}

// ─── ORG MODELS ──────────────────────────────────────────────────────────────

model Organization {
  id          String  @id @default(cuid())
  name        String
  slug        String  @unique
  image       String?

  members     OrganizationMember[]
  teams       Team[]
  invitations Invitation[]
  projects    Project[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model OrganizationMember {
  id   String     @id @default(cuid())
  role MemberRole @default(MEMBER)

  userId         String
  organizationId String

  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, organizationId])
}

model Team {
  id          String  @id @default(cuid())
  name        String
  identifier  String
  description String? @db.Text

  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  members  TeamMember[]
  projects Project[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([identifier, organizationId])
}

model TeamMember {
  id   String     @id @default(cuid())
  role MemberRole @default(MEMBER)

  userId String
  teamId String

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  team Team @relation(fields: [teamId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, teamId])
}

model Invitation {
  id      String     @id @default(cuid())
  email   String
  token   String     @unique
  role    MemberRole @default(MEMBER)
  expires DateTime

  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@unique([email, organizationId])
}

// ─── PROJECT ─────────────────────────────────────────────────────────────────

model Project {
  id             String       @id @default(cuid())
  name           String
  code           String
  description    String?      @db.Text
  status         String       @default("active")
  progress       Int          @default(0)
  velocityRisk   VelocityRisk @default(LOW)
  startDate      DateTime?
  endDate        DateTime?
  budgetUsed     Float        @default(0)
  budgetTotal    Float        @default(0)
  budgetCurrency String       @default("USD")

  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  teamId String
  team   Team   @relation(fields: [teamId], references: [id], onDelete: Cascade)

  creatorId String
  creator   User   @relation("ProjectCreator", fields: [creatorId], references: [id])

  milestones     Milestone[]
  activities     Activity[]
  boardColumns   BoardColumn[]
  vaultDocuments VaultDocument[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([code, organizationId])
}

// ─── MILESTONE ───────────────────────────────────────────────────────────────

model Milestone {
  id          String          @id @default(cuid())
  name        String
  description String?         @db.Text
  status      MilestoneStatus @default(NOT_STARTED)
  weight      Int             @default(1)
  dueDate     DateTime?

  projectId String
  project   Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  activities     Activity[]
  vaultDocuments VaultDocument[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ─── ACTIVITY ─────────────────────────────────────────────────────────────────

model Activity {
  id          String         @id @default(cuid())
  title       String
  description String?        @db.Text
  status      ActivityStatus @default(TODO)
  priority    Priority       @default(MEDIUM)
  powStatus   PowStatus      @default(NOT_SUBMITTED)
  dueDate     DateTime?
  tags        String[]

  projectId String
  project   Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  milestoneId String?
  milestone   Milestone? @relation(fields: [milestoneId], references: [id], onDelete: SetNull)

  assigneeId String?
  assignee   User?   @relation("ActivityAssignee", fields: [assigneeId], references: [id], onDelete: SetNull)

  subIssues      SubIssue[]
  placement      ActivityPlacement?
  powSubmissions PowSubmission[]
  attachments    VaultDocument[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ─── SUB-ISSUE ────────────────────────────────────────────────────────────────

model SubIssue {
  id    String  @id @default(cuid())
  title String
  done  Boolean @default(false)

  activityId String
  activity   Activity @relation(fields: [activityId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ─── KANBAN ───────────────────────────────────────────────────────────────────

model BoardColumn {
  id        String  @id @default(cuid())
  label     String
  position  Int
  dot       String  @default("#A3A3A3")
  isDefault Boolean @default(false)

  projectId String
  project   Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  placements ActivityPlacement[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// Activity ↔ BoardColumn placement (independent of activity.status)
model ActivityPlacement {
  activityId String   @id
  activity   Activity @relation(fields: [activityId], references: [id], onDelete: Cascade)

  columnId String
  column   BoardColumn @relation(fields: [columnId], references: [id], onDelete: Cascade)

  updatedAt DateTime @updatedAt
}

// ─── PROOF OF WORK ────────────────────────────────────────────────────────────

model PowSubmission {
  id         String    @id @default(cuid())
  status     PowStatus @default(AWAITING_REVIEW)
  notes      String?   @db.Text
  reviewedAt DateTime?

  activityId String
  activity   Activity @relation(fields: [activityId], references: [id], onDelete: Cascade)

  submitterId String
  submitter   User   @relation("PowSubmitter", fields: [submitterId], references: [id])

  reviewerId String?
  reviewer   User?   @relation("PowReviewer", fields: [reviewerId], references: [id])

  documents VaultDocument[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ─── VAULT ────────────────────────────────────────────────────────────────────

model VaultDocument {
  id       String   @id @default(cuid())
  name     String
  category String   @default("other")
  s3Key    String
  size     String
  mimeType String
  tags     String[]

  projectId String
  project   Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  milestoneId String?
  milestone   Milestone? @relation(fields: [milestoneId], references: [id], onDelete: SetNull)

  activityId String?
  activity   Activity? @relation(fields: [activityId], references: [id], onDelete: SetNull)

  powSubmissionId String?
  powSubmission   PowSubmission? @relation(fields: [powSubmissionId], references: [id], onDelete: SetNull)

  uploadedById String
  uploadedBy   User   @relation("VaultUploader", fields: [uploadedById], references: [id])

  createdAt DateTime @default(now())
}

// ─── NOTIFICATIONS ────────────────────────────────────────────────────────────

model Notification {
  id      String           @id @default(cuid())
  type    NotificationType
  message String
  payload Json?
  read    Boolean          @default(false)

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
}
